// Admin Iam Bounded Context

model AdminUser {
  id           String  @id @default(uuid()) @db.Uuid
  email        String  @unique @db.VarChar(255)
  isSuperAdmin Boolean @default(false)
  displayName  String  @db.VarChar(120)
  status       String  @db.VarChar(60)
  passwordHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version Int @default(1) @db.Integer
}

model AdminUserRead {
  id           String   @id @default(uuid()) @db.Uuid
  adminUserId  String   @unique @db.Uuid
  email        String   @unique @db.VarChar(255)
  isSuperAdmin Boolean
  displayName  String   @db.VarChar(120)
  status       String   @db.VarChar(60)
  createdAt    DateTime
  updatedAt    DateTime

  @@index([email])
  @@index([displayName])
  @@index([status])
}

// -----------------------------

// Organization Bounded Context

model Organization {
  id      String @id @default(uuid()) @db.Uuid
  name    String @db.VarChar(255)
  address String @db.VarChar(255)
  taxId   String @db.VarChar(120)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version Int @default(1) @db.Integer

  members OrganizationMember[]
}

model OrganizationMember {
  id                 String  @id @default(uuid()) @db.Uuid
  isRoot             Boolean @default(false)
  organizationUserId String  @db.Uuid

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @db.Uuid

  @@unique([organizationId, organizationUserId])
}

model OrganizationOrganizationUser {
  id                 String @id @default(uuid()) @db.Uuid
  organizationUserId String @unique @db.Uuid
  displayName        String @db.VarChar(120)
  email              String @unique @db.VarChar(255)

  @@index([organizationUserId, displayName, email])
}

model OrganizationListForAdminRead {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @unique @db.Uuid
  name           String @db.VarChar(255)
  address        String @db.VarChar(255)
  taxId          String @db.VarChar(120)
  members        Json
  version        Int    @db.Integer

  @@index([address, name, taxId])
}

// -----------------------------

// Organization User IAM Bounded Context

model OrganizationUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String?
  displayName  String   @db.VarChar(120)
  status       String   @db.VarChar(60)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  version Int @default(1) @db.Integer
}

model OrganizationUserRead {
  id                 String @id @default(uuid()) @db.Uuid
  organizationUserId String @unique @db.Uuid
  email              String @unique @db.VarChar(255)
  displayName        String @db.VarChar(120)
  statusText         String @db.VarChar(80)

  @@index([email, displayName])
}

// -----------------------------

// Cart Bounded Context

model Cart {
  id            String   @id @default(uuid()) @db.Uuid
  parkingSpotId String   @db.Uuid
  arrival       Int
  departure     Int
  days          Int
  priceByDay    Float
  createdAt     DateTime
  total         Float    @default(0)
  userId        String?  @db.Uuid
  addons        Json

  @@unique([id, parkingSpotId])
  @@index([userId])
}

// -----------------------------

// User IAM Bounded Context
model User {
  id           String  @id @default(uuid()) @db.Uuid
  email        String  @unique @db.VarChar(255)
  name         String  @db.VarChar(120)
  passwordHash String?
  provider     String  @db.VarChar(60)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRead {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  email     String   @unique @db.VarChar(255)
  name      String   @db.VarChar(120)
  provider  String   @db.VarChar(60)
  createdAt DateTime
  updatedAt DateTime

  @@index([email, name, provider])
}

// -----------------------------

// Reservation Bounded Context
model Reservation {
  id                 String   @id @default(uuid()) @db.Uuid
  cartId             String   @db.Uuid
  parkingSpotId      String   @db.Uuid
  parkingId          String   @db.Uuid
  userId             String   @db.Uuid
  arrival            Int
  departure          Int
  lines              Json
  total              Int
  status             String   @db.VarChar(20)
  registrationNumber String   @db.VarChar(20)
  addons             String[] @default([]) @db.VarChar(90)

  version   Int      @default(1) @db.Integer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReservationRead {
  id                 String   @id @default(uuid()) @db.Uuid
  reservationId      String   @unique @db.Uuid
  cartId             String   @db.Uuid
  parkingSpotId      String   @db.Uuid
  parkingId          String   @db.Uuid
  userId             String   @db.Uuid
  arrival            Int
  departure          Int
  lines              Json
  total              Int
  status             String   @db.VarChar(20)
  registrationNumber String   @db.VarChar(20)
  addons             String[] @default([]) @db.VarChar(90)

  version   Int      @db.Integer
  createdAt DateTime
  updatedAt DateTime

  @@index([registrationNumber, status, arrival, departure, userId])
}


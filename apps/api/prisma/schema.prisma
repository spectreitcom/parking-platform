generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Outbox

enum OutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DEAD_LETTER
}

model OutboxMessage {
  id String @id @default(uuid())

  /// Nazwa zdarzenia / typu wiadomości, np. "order.created"
  type String

  /// Opcjonalnie: nazwa bounded contextu / modułu
  boundedContext String?

  /// Typ agregatu, np. "Order", "User"
  aggregateType String?

  /// Id agregatu (np. UUID jako string)
  aggregateId String?

  /// Treść eventu - payload domenowy/integracyjny
  payload Json

  /// Nagłówki pomocnicze (traceId, correlationId, userId, itp.)
  headers Json?

  status OutboxStatus @default(PENDING)

  /// Ile razy próbowaliśmy wysłać tę wiadomość
  attemptCount Int @default(0)

  /// Kiedy ponowić próbę (dla backoffu)
  nextRetryAt DateTime?

  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deduplicationKey String? @unique

  @@index([status, nextRetryAt])
  @@index([boundedContext])
  @@index([aggregateType, aggregateId])
  @@index([createdAt])
  @@index([updatedAt])
}

// -----------------------------

// Parking Bounded Context

model PlaceType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(60)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1) @db.Integer
  places    Place[]
}

model PlaceTypeRead {
  id          String @id @default(uuid()) @db.Uuid
  placeTypeId String @unique @db.Uuid
  name        String @unique @db.VarChar(60)
  version     Int

  @@index([name])
}

model ParkingAddon {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(60)
  name      String    @db.VarChar(255)
  price     Int       @default(0) // In grosze
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  version   Int       @default(1) @db.Integer
  parkings  Parking[]
}

model ParkingAddonRead {
  id             String  @id @default(uuid()) @db.Uuid
  parkingAddonId String  @unique @db.Uuid
  name           String  @db.VarChar(255)
  code           String  @unique @db.VarChar(60)
  price          Int     @default(0)
  priceInPln     Decimal @default(0) @db.Decimal(10, 2)
  version        Int

  @@index([name, code, priceInPln])
}

model Place {
  id        String  @id @default(uuid()) @db.Uuid
  name      String  @unique @db.VarChar(255)
  longitude Decimal @db.Decimal(10, 7)
  latitude  Decimal @db.Decimal(10, 7)
  active    Boolean @default(true)
  address   String  @db.VarChar(255)

  placeTypeId String    @db.Uuid
  placeType   PlaceType @relation(fields: [placeTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version Int @default(1) @db.Integer

  parkings Parking[]
}

model PlaceRead {
  id            String  @id @default(uuid()) @db.Uuid
  placeId       String  @unique @db.Uuid
  name          String  @unique @db.VarChar(255)
  longitude     Decimal @db.Decimal(10, 7)
  latitude      Decimal @db.Decimal(10, 7)
  active        Boolean
  address       String  @db.VarChar(255)
  placeTypeId   String  @db.Uuid
  placeTypeName String  @db.VarChar(60)
  version       Int     @db.Integer

  @@index([name, longitude, latitude, address, placeTypeId])
}

model ParkingFeature {
  id     String   @id @default(uuid()) @db.Uuid
  levels String[] @db.VarChar(60)
  name   String   @unique @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version Int @default(1) @db.Integer

  parkings     Parking[]
  parkingSpots ParkingSpot[]
}

model ParkingFeatureRead {
  id               String   @id @default(uuid()) @db.Uuid
  parkingFeatureId String   @unique @db.Uuid
  name             String   @unique @db.VarChar(255)
  levels           String[] @db.VarChar(60)
  version          Int

  @@index([name])
}

model Parking {
  id        String  @id @default(uuid()) @db.Uuid
  name      String  @unique @db.VarChar(255)
  longitude Decimal @db.Decimal(10, 7)
  latitude  Decimal @db.Decimal(10, 7)

  statute        String? @db.Text
  description    String? @db.Text
  organizationId String  @db.Uuid

  assetIds String[] @default([]) @db.Uuid

  parkingFeatures ParkingFeature[]
  parkingAddons   ParkingAddon[]

  placeId String @db.Uuid
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  active  Boolean @default(false)
  address String  @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version Int @default(1) @db.Integer

  parkingSpots ParkingSpot[]
}

model ParkingRead {
  id        String  @id @default(uuid()) @db.Uuid
  parkingId String  @unique @db.Uuid
  name      String  @unique @db.VarChar(255)
  longitude Decimal @db.Decimal(10, 7)
  latitude  Decimal @db.Decimal(10, 7)

  statute        String? @db.Text
  description    String? @db.Text
  organizationId String  @db.Uuid

  assetIds String[] @default([]) @db.Uuid

  parkingFeatureIds String[] @default([]) @db.Uuid
  parkingAddonIds   String[] @default([]) @db.Uuid

  placeId String @db.Uuid

  active  Boolean @default(false)
  address String  @db.VarChar(255)

  createdAt DateTime
  updatedAt DateTime

  version Int @db.Integer

  @@index([name, organizationId, placeId])
}

model ParkingSpot {
  id     String  @id @default(uuid()) @db.Uuid
  price  Int
  active Boolean @default(true)

  parkingId String  @db.Uuid
  parking   Parking @relation(fields: [parkingId], references: [id], onDelete: Cascade)

  parkingSpotFeatures ParkingFeature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version Int @default(1) @db.Integer
}

model ParkingOrganization {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @unique @db.Uuid
  name           String @db.VarChar(255)
  address        String @db.VarChar(255)
}

model ParkingListForAdminRead {
  id                 String  @id @default(uuid()) @db.Uuid
  parkingId          String  @db.Uuid
  organizationId     String  @db.Uuid
  placeId            String  @db.Uuid
  parkingName        String  @db.VarChar(255)
  parkingAddress     String  @db.VarChar(255)
  placeName          String  @db.VarChar(255)
  parkingActive      Boolean
  parkingSpotsNumber Int     @default(0)
  organizationName   String  @db.VarChar(255)
  version            Int     @db.Integer
  distance           Float   @default(0)

  @@unique([parkingId, organizationId])
  @@index([parkingName, organizationName, placeName])
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Parking Bounded Context

model ParkingType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(60)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

